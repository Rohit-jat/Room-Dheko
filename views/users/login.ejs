<% layout("/layouts/boilerplate") -%>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap');

  .login-fullscreen {
    position: fixed;
    top: 0; left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 999;
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #faf9f6;
    overflow: hidden;
  }

  .lp-left {
    background: #1a5c3a;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .lp-left::before {
    content: '';
    position: absolute;
    width: 280px; height: 280px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.07);
    top: -90px; right: -90px;
  }
  .lp-left::after {
    content: '';
    position: absolute;
    width: 170px; height: 170px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.05);
    bottom: 50px; left: -50px;
  }
  .lp-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1rem;
  }
  .lp-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 2.8vw, 2.6rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 0.8rem;
  }
  .lp-headline em { font-style: italic; color: #7de0a8; }
  .lp-divider { width: 36px; height: 1.5px; background: rgba(255,255,255,0.15); margin-bottom: 1.2rem; }
  .lp-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.75;
  }
  .lp-stats { display: flex; gap: 2rem; }
  .lp-stat-num { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: #fff; display: block; }
  .lp-stat-lbl { font-family: 'DM Sans', sans-serif; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.35); }

  .lp-right {
    background: #faf9f6;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow-y: auto;
  }
  .lp-form-inner { width: 100%; max-width: 380px; margin: 0 auto; }
  .lp-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'DM Sans', sans-serif; font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: #2d7a52; font-weight: 500; margin-bottom: 1rem;
  }
  .lp-tag::before { content: ''; display: block; width: 18px; height: 1.5px; background: #2d7a52; }
  .lp-form-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.3rem; }
  .lp-form-sub { font-family: 'DM Sans', sans-serif; font-size: 13px; color: #6b7280; margin-bottom: 2rem; }
  .lp-field { margin-bottom: 1.1rem; }
  .lp-field label {
    display: block; font-family: 'DM Sans', sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; color: #1a1a1a; margin-bottom: 0.45rem;
  }
  .lp-inp-wrap { position: relative; }
  .lp-inp-wrap svg {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    width: 15px; height: 15px; color: #9ca3af; pointer-events: none;
  }
  .lp-inp-wrap input {
    width: 100%; padding: 0.72rem 0.85rem 0.72rem 2.5rem;
    border: 1.5px solid #d4e6da; border-radius: 10px;
    font-family: 'DM Sans', sans-serif; font-size: 14px;
    color: #1a1a1a; background: #fff; outline: none;
    transition: border-color 0.18s, box-shadow 0.18s; box-sizing: border-box;
  }
  .lp-inp-wrap input:focus { border-color: #2d7a52; box-shadow: 0 0 0 3px rgba(45,122,82,0.1); }
  .lp-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1.5rem; font-family: 'DM Sans', sans-serif; font-size: 12.5px;
  }
  .lp-remember { display: flex; align-items: center; gap: 6px; color: #6b7280; cursor: pointer; }
  .lp-remember input { accent-color: #2d7a52; }
  .lp-forgot { color: #2d7a52; text-decoration: none; font-weight: 500; }
  .lp-btn {
    width: 100%; padding: 0.8rem; background: #1a5c3a; color: #fff;
    border: none; border-radius: 10px; font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 500; letter-spacing: 0.04em;
    cursor: pointer; transition: background 0.2s, transform 0.12s;
  }
  .lp-btn:hover { background: #2d7a52; }
  .lp-btn:active { transform: scale(0.99); }
  .lp-signup { text-align: center; margin-top: 1.2rem; font-family: 'DM Sans', sans-serif; font-size: 12.5px; color: #6b7280; }
  .lp-signup a { color: #2d7a52; font-weight: 500; text-decoration: none; }
  .lp-invalid { font-family: 'DM Sans', sans-serif; font-size: 11.5px; color: #e05c5c; margin-top: 0.35rem; display: none; }
  .was-validated .lp-inp-wrap input:invalid ~ .lp-invalid { display: block; }

  @media (max-width: 700px) {
    .login-fullscreen { grid-template-columns: 1fr; }
    .lp-left { display: none; }
  }
</style>

<div class="login-fullscreen">

  <div class="lp-left">
    <div>
      <p class="lp-eyebrow">Room Dheko</p>
      <h1 class="lp-headline">Find your <em>perfect</em><br>room today.</h1>
      <div class="lp-divider"></div>
      <p class="lp-desc">Thousands of verified listings.<br>Connect with landlords directly and move in — fast, simple, and stress-free.</p>
    </div>
    <div class="lp-stats">
      <div><span class="lp-stat-num">12K+</span><span class="lp-stat-lbl">Listings</span></div>
      <div><span class="lp-stat-num">8K+</span><span class="lp-stat-lbl">Tenants</span></div>
      <div><span class="lp-stat-num">50+</span><span class="lp-stat-lbl">Cities</span></div>
    </div>
  </div>

  <div class="lp-right">
    <div class="lp-form-inner">
      <span class="lp-tag">Welcome back</span>
      <h2 class="lp-form-title">Sign in</h2>
      <p class="lp-form-sub">Enter your credentials to access your account.</p>

      <form method="post" action="/login" class="needs-validation" novalidate
            onsubmit="this.classList.add('was-validated')">

        <div class="lp-field">
          <label for="username">Username</label>
          <div class="lp-inp-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <input id="username" name="username" type="text" placeholder="your_username" required>
            <div class="lp-invalid">Please enter your username.</div>
          </div>
        </div>

        <div class="lp-field">
          <label for="password">Password</label>
          <div class="lp-inp-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input id="password" name="password" type="password" placeholder="••••••••" required>
            <div class="lp-invalid">Please enter your password.</div>
          </div>
        </div>

        <div class="lp-row">
          <label class="lp-remember">
            <input type="checkbox"> Remember me
          </label>
          <a href="/forgot-password" class="lp-forgot">Forgot password?</a>
        </div>

        <button type="submit" class="lp-btn">Sign In</button>
      </form>

      <p class="lp-signup">
        Don't have an account? <a href="/signup">Create one →</a>
      </p>
    </div>
  </div>

</div>
